#!/usr/bin/env zsh
#
# private_env.zsh — Private environment variables
#
# INSTRUCTIONS:
#   1. Copy this file to private_env.zsh in the same directory:
#        cp private_env.zsh.template private_env.zsh
#   2. Fill in your actual values
#   3. Run install.zsh to symlink to ~/.config/private_env.zsh
#   4. NEVER commit private_env.zsh — only the template is tracked
#
# This file is sourced by .zprofile on login and .zshrc as a fallback.
# All values are available to child processes via export.
#

###############################################################################
# Personal Identity
###############################################################################
export GITHUB_USER_NAME=""
