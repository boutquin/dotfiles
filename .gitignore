########################################################
# Project-Level .gitignore
# ------------------------------------------------------
# Keep OS-specific ignores in your global Git ignore.
# Only include artifacts and files unique to this project
# or to the languages/frameworks used here.
########################################################

########################################################
# Node.js / JavaScript Artifacts
########################################################
# Dependency directory created by npm, Yarn, or PNPM
node_modules
# Log file generated by npm on errors
npm-debug.log
# Error log generated by Yarn
yarn-error.log
# Lockfile from PNPM (typically project-specific)
pnpm-lock.yaml

########################################################
# Ruby / Rails / Bundler
########################################################
# RubyGems package files
*.gem
# Compiled Ruby files
*.rbc
# Bundler's local configuration
.bundle
# Bundler-installed vendor dependencies
vendor/bundle
# Rails log files
log/*
# Rails temp files
tmp/*
# Allow empty directory markers
!log/.keep
!tmp/.keep
# Vim swap files
*.swp
*.swo
# Test coverage reports
coverage/
# Byebug debugging history
.byebug_history
# RVM config file
.rvmrc
# rbenv environment variables
.rbenv-vars
# Common pattern for local environment variables
.env

########################################################
# Python (if any scripts in this repo)
########################################################
# Python byte-compiled script cache
__pycache__/
# Byte-compiled Python
*.pyc
*.pyo
*.pyd
*.pyd-dll

########################################################
# Visual Studio Code
########################################################
# VS Code workspace settings (if you prefer not to commit them)
.vscode/
# VSCode extensions or other local history trackers
.history/

########################################################
# Miscellaneous / Secrets
########################################################
# Files storing secret tokens or data
*.secret
# Environment variable files
*.env
# Local overrides for environment
*.env.local
# direnv or other environment loaders
.envrc
# Personal environment files (only template is tracked)
private_env.*
# Allow templates to be tracked
!private_env.*.template

########################################################
# End of .gitignore
########################################################
# Claude Code session logs (private workspace)
sessions/

# Timestamped backup artifacts ([file].bak.YYYY-MM-DD-HHMM)
*.bak
*.bak.*
